# Environment and secrets (keep .env.example)
.env
.env.local
.env.*.local

# Agent debug logs (--debug); keep folder via logs/.gitkeep
logs/*
!logs/.gitkeep
agent_debug_*.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
