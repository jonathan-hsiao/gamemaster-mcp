*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# Hugging Face / sentence-transformers cache (models, tokenizers)
.cache/

# Generated store (SQLite DB, FAISS index) — created by ingest; keep folder via .gitkeep
rules_store/*
!rules_store/.gitkeep

# User rulebooks (configurable via RULEBOOKS_DIR; often local PDFs); keep folder via .gitkeep
rulebooks/*
!rulebooks/.gitkeep

# Planning docs
planning/

