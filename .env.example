# Copy to .env and set values. Sections below: server (run-mcp, ingest-rulebook) vs client (ask-agent).
# If you build your own client against this MCP server, you only need the "MCP server" section.
# Example values are populated with config defaults.

# ========== MCP server ==========
# Required for run-mcp and ingest-rulebook. Set these when running the server or any host that runs this server.

# --- Paths ---
# Root for PDFs: ingest paths must resolve under this directory.
# RULEBOOKS_DIR=rulebooks
# Where to store SQLite DB and FAISS index.
# RULES_STORE_DIR=rules_store

# --- Ingest ---
# Minimum chars per page to accept a PDF (reject scanned/image PDFs).
# TEXT_DENSITY_MIN_CHARS_PER_PAGE=100

# --- Retrieval (search_rules, get_chunks) ---
# get_chunks caps: max chunks per call, max chars per chunk.
# GET_CHUNKS_MAX_CHUNKS=20
# GET_CHUNKS_MAX_CHARS=4000
# search_rules: max candidates from sparse (FTS) and dense (FAISS) before merge/rerank.
# SEARCH_K_SPARSE=50
# SEARCH_K_DENSE=50

# --- Models (embedder + reranker) ---
# EMBED_MODEL=intfloat/e5-small-v2
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Hugging Face ---
# HF_TOKEN=      # Optional for gated models or higher rate limits
# Cache dirs
# HF_HOME=.cache/huggingface
# TRANSFORMERS_CACHE=.cache/huggingface/transformers
# HF_HUB_CACHE=.cache/huggingface/hub


# ========== Client / agent ==========
# Only for the included ask-agent CLI. Not needed if you use your own client (Cursor, Claude Desktop, etc.).

# --- LLM ---
OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-5-mini

# --- Debug ---
# Where --debug writes agent logs (prompts, tool calls, responses).
# AGENT_DEBUG_LOG_DIR=logs
